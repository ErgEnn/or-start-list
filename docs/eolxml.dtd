>
<!ELEMENT Note (#PCDATA)>
<!ATTLIST Note
	lang CDATA "EST"
>
<!-- Lisatud tyybid ControlCard ja Map -->
<!ELEMENT PunchMethod EMPTY>
<!ATTLIST PunchMethod
	type (SI | Emit | Map | ControlCard | Manual | other) #REQUIRED
>
<!ELEMENT Registration (IvkID?, Entrydate*, Feeperdays, Regnote*)>
<!ELEMENT IvkID (#PCDATA)>
