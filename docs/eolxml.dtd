******************************************************************* 
 -->
<!--  Runner result export/import with route drawing -->
<!ELEMENT OMExport (OMexportVersion, Name, EventName, Date, ClassShortName, Result?, Route?, Comment?)>
<!ELEMENT OMexportVersion (#PCDATA)>
<!ATTLIST OMexportVersion
	version CDATA #REQUIRED
>
<!ELEMENT EventName (#PCDATA)>
<!-- Result kasutatakse AINULT (Time,CompetitorStatus?,SplitTime*) -->
<!ELEMENT Route (BaseMap, Points*)>
<!ELEMENT BaseMap (file)>
<!ATTLIST BaseMap
	dpi CDATA #REQUIRED
	height CDATA #REQUIRED
	width CDATA #REQUIRED
	scale CDATA #REQUIRED
>
<!ELEMENT file (#PCDATA)>
<!ELEMENT Points (x, y)>
<!ATTLIST Points
	sequence CDATA #REQUIRED
	type (START | CONTROL | MARKEDROUTE | RUN | RUN50 | STOP | FINISH | EXTRACONTROL) #REQUIRED
	text CDATA #REQUIRED
>
<!ELEMENT x (#PCDATA)>
<!ELEMENT y (#PCDATA)>
<!--  
EOL online service description 
-->
<!ELEMENT ServiceList (EOLwebService*)>
<!ELEMENT EOLwebService (Name, WebURL, ValidFrom, ValidTo?, Comment?, LastUpdate?, Moderator?)>
<!ATTLIST EOLwebService
	type (REGISTRATION | EVENT | RESULT | PERSONAL | MAP | ROUTE | DOC | EOLAB) #REQUIRED
>
<!ELEMENT ValidFrom (#PCDATA)>
<!ELEMENT ValidTo (#PCDATA)>
<!ELEMENT LastUpdate (#PCDATA)>
<!ELEMENT Moderator (Name, Email)>
<!ELEMENT Email (#PCDATA)>
