{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@or/shared": [
        "packages/shared/src/index.ts"
      ],
      "@or/eol-import": [
        "packages/eol-import/src/index.ts"
      ]
    }
  }
}

